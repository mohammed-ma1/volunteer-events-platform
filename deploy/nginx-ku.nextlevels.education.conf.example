# HTTPS for ku.nextlevels.education (Angular SPA + Laravel /api on one host).
#
# === 1) DNS (name.com → Manage DNS Records for nextlevels.education) ===
# Add ONE of:
#   Type A,  Host ku,  Value YOUR_DROPLET_PUBLIC_IP, TTL 300
#   Type AAAA, Host ku,  Value YOUR_VPS_IPV6 (optional)
# Wait for propagation (often a few minutes; dig ku.nextlevels.education +short).
#
# === 2) On the VPS (Ubuntu-style) ===
#   sudo apt update && sudo apt install -y nginx php8.3-fpm  # adjust PHP version
#   sudo mkdir -p /var/www/volunteer-events
#   # Deploy code: frontend/dist/frontend/browser + backend with public/
#   sudo cp deploy/nginx-ku.nextlevels.education.conf.example \
#          /etc/nginx/sites-available/ku.nextlevels.education
#   # Edit paths below if your tree differs; then:
#   sudo ln -sf /etc/nginx/sites-available/ku.nextlevels.education /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# === 3) TLS (Let's Encrypt) ===
#   sudo apt install -y certbot python3-certbot-nginx
#   sudo certbot --nginx -d ku.nextlevels.education
# Certbot will add ssl_certificate and listen 443 to this server block.
#
# === 4) Laravel .env on the server ===
#   APP_URL=https://ku.nextlevels.education
#   FRONTEND_URL=https://ku.nextlevels.education
#   CORS_ALLOWED_ORIGINS=https://ku.nextlevels.education
#   APP_DEBUG=false
#   php artisan config:cache
#
# Frontend production build already uses apiUrl: '/api' (same origin).

server {
    listen 80;
    listen [::]:80;
    server_name ku.nextlevels.education;

    root /var/www/volunteer-events/frontend/dist/frontend/browser;
    index index.html;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    location = /up {
        include fastcgi_params;
        fastcgi_param HTTP_X_FORWARDED_PROTO $scheme;
        fastcgi_param HTTP_X_FORWARDED_FOR $proxy_add_x_forwarded_for;
        fastcgi_param SCRIPT_FILENAME /var/www/volunteer-events/backend/public/index.php;
        fastcgi_param DOCUMENT_ROOT /var/www/volunteer-events/backend/public;
        fastcgi_param REQUEST_URI $request_uri;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
    }

    location ^~ /api/ {
        include fastcgi_params;
        fastcgi_param HTTP_X_FORWARDED_PROTO $scheme;
        fastcgi_param HTTP_X_FORWARDED_FOR $proxy_add_x_forwarded_for;
        fastcgi_param SCRIPT_FILENAME /var/www/volunteer-events/backend/public/index.php;
        fastcgi_param DOCUMENT_ROOT /var/www/volunteer-events/backend/public;
        fastcgi_param REQUEST_URI $request_uri;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;
}
