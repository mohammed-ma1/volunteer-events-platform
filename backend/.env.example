APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# After Tap checkout, the user is sent here. Chrome often blocks Tap (public HTTPS) → localhost.
# For local Tap testing use a public tunnel and match this value, e.g. `ngrok http 4200`:
#   FRONTEND_URL=https://YOUR_SUBDOMAIN.ngrok-free.app
# and add the same origin to CORS_ALLOWED_ORIGINS (comma-separated).
FRONTEND_URL=http://localhost:4200
# Exact origins (production HTTPS, ngrok, etc.). Local dev also allows any localhost / 127.0.0.1 port via config/cors.php patterns.
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- Production (single host: Angular + Laravel under one HTTPS domain, e.g. kw.nextlevels.education) ---
# APP_URL=https://kw.nextlevels.education
# FRONTEND_URL=https://kw.nextlevels.education   # Tap iframe/redirect; must match public site (not localhost)
# CORS_ALLOWED_ORIGINS=https://kw.nextlevels.education
# TAP_MOCK=false
# APP_DEBUG=false
# See deploy/nginx-kw.nextlevels.education.conf.example and Let's Encrypt steps in that file header.

# Tap Payments: TAP_SECRET_KEY is the server Bearer token (Create Charge). Never expose in the frontend.
# Use sk_test_/pk_test_ in development; sk_live_/pk_live_ only in production.
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
# Merchant ID / Account ID from Tap Dashboard (goSell > API Credentials).
TAP_MERCHANT_ID=
TAP_API_BASE=https://api.tap.company/v2
TAP_SOURCE_ID=src_all
# Local only (APP_ENV=local): mock Tap + /checkout/tap-return?mock=1 + POST /api/v1/orders/{uuid}/mock-complete.
# Ignored in production/staging; set TAP_MOCK=false on servers.
TAP_MOCK=true
TAP_WEBHOOK_VERIFY=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (local default): DB_CONNECTION=sqlite  and leave DB_* unset except optional DB_DATABASE path
# MySQL (e.g. server): use the block below.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=volunteer_events
DB_USERNAME=ve_app
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# After payment, a receipt is emailed once per order. Use `log` locally (see storage/logs/laravel.log) or SMTP in production.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.edu.kw"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
