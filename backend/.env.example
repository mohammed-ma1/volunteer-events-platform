APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# After Tap checkout, the user is sent here. Chrome often blocks Tap (public HTTPS) → localhost.
# For local Tap testing use a public tunnel and match this value, e.g. `ngrok http 4200`:
#   FRONTEND_URL=https://YOUR_SUBDOMAIN.ngrok-free.app
# and add the same origin to CORS_ALLOWED_ORIGINS (comma-separated).
FRONTEND_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Tap Payments: use TAP_SECRET_KEY server-side only (Create Charge Bearer token). Never expose in the frontend.
TAP_SECRET_KEY=
# Optional: public key for Tap.js / Card SDK only; not used for hosted charge + iframe flow.
TAP_PUBLIC_KEY=
# Optional: Merchant ID from Tap Dashboard (goSell > API Credentials) — include when Tap requires it on charges.
TAP_MERCHANT_ID=
TAP_API_BASE=https://api.tap.company/v2
TAP_SOURCE_ID=src_all
TAP_MOCK=true
TAP_WEBHOOK_VERIFY=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# After payment, a receipt is emailed once per order. Use `log` locally (see storage/logs/laravel.log) or SMTP in production.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.edu.kw"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
